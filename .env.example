# summon-claude configuration
# Copy this file to .env and fill in your values.

# --- Required: Slack App credentials ---
# Bot token (xoxb-...) — from "OAuth & Permissions" in your Slack app settings
SUMMON_SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token (xapp-...) — from "Basic Information > App-Level Tokens"
# Requires the connections:write scope for Socket Mode
SUMMON_SLACK_APP_TOKEN=xapp-your-app-token-here

# Signing secret — from "Basic Information > App Credentials"
SUMMON_SLACK_SIGNING_SECRET=your-signing-secret-here

# --- Required: Authorization ---
# Comma-separated list of Slack user IDs allowed to use summon
# Find your user ID: Slack profile > ... > Copy member ID
SUMMON_ALLOWED_USER_IDS=U0123456789,U9876543210

# --- Optional: Claude model ---
# Default model to use for sessions
SUMMON_DEFAULT_MODEL=claude-opus-4-6

# --- Optional: Slack channel prefix ---
# Prefix for created session channels (default: summon)
SUMMON_CHANNEL_PREFIX=summon

# --- Optional: Permission handling ---
# Debounce window in milliseconds for batching permission requests
SUMMON_PERMISSION_DEBOUNCE_MS=500

# Content length threshold for inline vs file upload (characters)
SUMMON_MAX_INLINE_CHARS=2500

# --- Optional: Vertex AI ---
# Enable Vertex AI backend instead of direct Anthropic API
SUMMON_USE_VERTEX=false
# SUMMON_VERTEX_PROJECT_ID=your-gcp-project-id
# SUMMON_VERTEX_REGION=us-east5

# When using Vertex AI, also set these Google Cloud credentials:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# or use: gcloud auth application-default login
